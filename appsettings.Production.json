{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "JwtSettings": {
    "Issuer": "EmployeeManagement.API",
    "Audience": "EmployeeManagement.API",
    "SecretKey": "",
    "ExpirationMinutes": 30,
    "ValidateIssuer": true,
    "ValidateAudience": true
  },
  "CacheSettings": {
    "DurationMinutes": 15
  },
  "KeyVaultSettings": {
    "Enabled": true,
    "VaultUri": "https://aaki-kv.vault.azure.net/",
    "ConnectionStringSecretName": "SqlConnectionString",
    "JwtSecretKeySecretName": "JwtSecretKey",
    "TenantId": ""
  },
  "ApplicationInsights": {
    "ConnectionString": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
